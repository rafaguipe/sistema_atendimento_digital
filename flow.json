        "id": "919a6f18acda2815",
        "type": "function",
        "z": "03a45a332f1f80c7",
        "name": "historico",
        "func": "let fila = flow.get(\"fila\") || [];\n\nlet telefone = msg.req.query.telefone;\n\nif (!telefone) {\n    msg.payload = {\n        status: \"erro\",\n        mensagem: \"Telefone não informado\"\n    };\n    return msg;\n}\n\n// filtra pelo telefone\nlet historico = fila.filter(item => item.telefone == telefone);\n\n// ordena do mais recente para o mais antigo\nhistorico.sort((a, b) => b.data - a.data);\n\nmsg.payload = {\n    status: \"ok\",\n    total: historico.length,\n    historico: historico\n};\n\nreturn msg;",
