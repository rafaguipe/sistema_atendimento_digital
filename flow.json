        "name": "atendimento",
        "func": "let fila = flow.get(\"fila\") || [];\n\nlet id = msg.payload.id;\n\nfila = fila.map(item => {\n    if (item.id == id) {\n        item.status = \"atendendo\";\n    }\n    return item;\n});\n\nflow.set(\"fila\", fila);\n\nmsg.payload = { status: \"atendendo\" };\n\nreturn msg;",
