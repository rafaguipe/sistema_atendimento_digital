    {
        "id": "73ea25c0fb889819",
        "type": "function",
        "z": "03a45a332f1f80c7",
        "name": "function 6",
        "func": "let fila = flow.get(\"fila\") || [];\n\nlet resposta = {\n    novos: [],\n    atendendo: [],\n    finalizados: []\n};\n\nfila.forEach(item => {\n    if (item.status === \"novo\") {\n        resposta.novos.push(item);\n    } else if (item.status === \"atendendo\") {\n        resposta.atendendo.push(item);\n    } else if (item.status === \"finalizado\") {\n        resposta.finalizados.push(item);\n    }\n});\n\n// ordenar\nresposta.novos.sort((a, b) => Number(b.data) - Number(a.data));\nresposta.atendendo.sort((a, b) => Number(b.data) - Number(a.data));\nresposta.finalizados.sort((a, b) => Number(b.data) - Number(a.data));\n\nmsg.payload = resposta;\nreturn msg;",
