    {
        "id": "2016e5fd07a7a7b3",
        "type": "function",
        "z": "03a45a332f1f80c7",
        "name": "salvar_na_fila",
        "func": "// 🔥 função de padronizar telefone\nfunction limparTelefone(tel) {\n    if (!tel) return \"\";\n    return tel.toString().replace(/\\D/g, '');\n}\n\nlet fila = flow.get(\"fila\") || [];\n\n// normaliza telefone recebido\nlet telefone = limparTelefone(msg.payload.telefone);\n\n// garante que toda a fila está padronizada\nfila = fila.map(item => {\n    item.telefone = limparTelefone(item.telefone);\n    return item;\n});\n\n// verifica se já existe atendimento ativo\nlet existente = fila.find(item => \n    item.telefone === telefone && item.status !== \"finalizado\"\n);\n\nif (existente) {\n    msg.payload = {\n        status: \"erro\",\n        mensagem: \"Você já possui um atendimento em andamento.\"\n    };\n    return msg;\n}\n\n// cria novo atendimento\nlet novoItem = {\n    id: Date.now(),\n    nome: msg.payload.nome,\n    telefone: telefone, // já padronizado\n    mensagem: msg.payload.mensagem,\n    tipo: msg.tipo,\n    status: \"novo\",\n    data: Date.now()\n};\n\nfila.push(novoItem);\n\n// salva\nflow.set(\"fila\", fila);\n\nmsg.payload = {\n    status: \"ok\",\n    mensagem: \"Atendimento aberto com sucesso\",\n    tipo: msg.tipo,\n    id: novoItem.id\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
