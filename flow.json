    {
        "id": "eb7244223b7b3d96",
        "type": "function",
        "z": "03a45a332f1f80c7",
        "name": "classificar",
        "func": "let msgTexto = (msg.payload.mensagem || \"\").toLowerCase();\n\nlet tipo = \"outros\";\n\nif (msgTexto.includes(\"consulta\")) {\n    tipo = \"consulta\";\n} else if (msgTexto.includes(\"exame\")) {\n    tipo = \"exame\";\n} else if (msgTexto.includes(\"retorno\")) {\n    tipo = \"retorno\";\n}\n\nmsg.tipo = tipo;\nreturn msg;",
