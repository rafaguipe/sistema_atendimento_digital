    {
        "id": "0d4e13c15e270cb0",
        "type": "function",
        "z": "03a45a332f1f80c7",
        "name": "finalizar",
        "func": "let fila = flow.get(\"fila\") || [];\n\nlet id = msg.payload.id;\n\nlet encontrado = false;\n\nfila = fila.map(item => {\n    if (item.id == id) {\n        item.status = \"finalizado\";\n        encontrado = true;\n    }\n    return item;\n});\n\nflow.set(\"fila\", fila);\n\nif (encontrado) {\n    msg.payload = {\n        status: \"ok\",\n        id: id,\n        mensagem: \"Atendimento finalizado\"\n    };\n} else {\n    msg.payload = {\n        status: \"erro\",\n        id: id,\n        mensagem: \"ID não encontrado\"\n    };\n}\n\nreturn msg;",
