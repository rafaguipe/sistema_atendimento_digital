        "id": "81b9053bab80d6ba",
        "type": "function",
        "z": "03a45a332f1f80c7",
        "name": "abertos",
        "func": "// 🔥 função para padronizar telefone\nfunction limparTelefone(tel) {\n    if (!tel) return \"\";\n    return tel.toString().replace(/\\D/g, '');\n}\n\nlet fila = flow.get(\"fila\") || [];\n\n// pega telefone da query\nlet telefone = msg.req.query.telefone;\n\n// valida\nif (!telefone) {\n    msg.payload = {\n        status: \"erro\",\n        mensagem: \"Telefone não informado\"\n    };\n    return msg;\n}\n\n// normaliza telefone recebido\ntelefone = limparTelefone(telefone);\n\n// filtra apenas:\n// - mesmo telefone\n// - não finalizado\nlet abertos = fila.filter(item => \n    limparTelefone(item.telefone) === telefone &&\n    item.status !== \"finalizado\"\n);\n\n// ordena (mais recente primeiro)\nabertos.sort((a, b) => Number(b.data) - Number(a.data));\n\nmsg.payload = {\n    status: \"ok\",\n    total: abertos.length,\n    abertos: abertos\n};\n\nreturn msg;",
